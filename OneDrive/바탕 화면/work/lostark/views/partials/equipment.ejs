<section class="card">
  <h2>장비</h2>
  <div class="muted small">업데이트: <%= equipment?.updatedAt ?? '-' %></div>

  <% if (!equipment || !equipment.list || equipment.list.length === 0) { %>
    <p class="muted">장비 데이터가 없거나 가져오지 못했습니다.</p>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>이름</th>
            <th>타입</th>
            <th>품질</th>
          </tr>
        </thead>
        <tbody>
          <% equipment.list.forEach(it => { %>
            <tr>
              <td><%= it?.Name ?? '-' %></td>
              <td><%= it?.Type ?? it?.ItemType ?? '-' %></td>
              <td><%= it?.Quality ?? '-' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <details>
      <summary>원본(JSON) 보기</summary>
      <pre><%= JSON.stringify(equipment.list, null, 2) %></pre>
    </details>
  <% } %>
</section>
